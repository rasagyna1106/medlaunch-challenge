{
    "_comment": "Least-privilege IAM policy.",
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3ReadRawData",
            "Effect": "Allow",
            "Action": ["s3:GetObject", "s3:ListBucket"],
            "Resource": [
                "arn:aws:s3:::medlaunch-techchallenge-rasagyna",
                "arn:aws:s3:::medlaunch-techchallenge-rasagyna/raw/*"
            ]
        },
        {
            "Sid": "S3WriteOutputData",
            "Effect": "Allow",
            "Action": ["s3:PutObject", "s3:DeleteObject"],
            "Resource": [
                "arn:aws:s3:::medlaunch-techchallenge-rasagyna/output/*",
                "arn:aws:s3:::medlaunch-techchallenge-rasagyna/athena-results/*"
            ]
        },
        {
            "Sid": "AthenaQueryExecution",
            "Effect": "Allow",
            "Action": [
                "athena:StartQueryExecution",
                "athena:GetQueryExecution",
                "athena:GetQueryResults",
                "athena:StopQueryExecution",
                "athena:ListQueryExecutions"
            ],
            "Resource": ["arn:aws:athena:us-east-1:251335055169:workgroup/primary"]
        },
        {
            "Sid": "GlueCatalogAccess",
            "Effect": "Allow",
            "Action": [
                "glue:GetDatabase",
                "glue:GetTable",
                "glue:GetPartitions",
                "glue:CreateTable",
                "glue:DeleteTable"
            ],
            "Resource": [
                "arn:aws:glue:us-east-1:251335055169:catalog",
                "arn:aws:glue:us-east-1:251335055169:database/default",
                "arn:aws:glue:us-east-1:251335055169:table/default/healthcare_facilities",
                "arn:aws:glue:us-east-1:251335055169:table/default/facility_metrics"
            ]
        },
        {
            "Sid": "CloudWatchLogsForLambda",
            "Effect": "Allow",
            "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
            "Resource": ["arn:aws:logs:us-east-1:251335055169:log-group:/aws/lambda/medlaunch-facility-processor:*"]
        }
    ]
}
